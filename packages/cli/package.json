{
  "name": "arkantos",
  "version": "1.0.0",
  "description": "A CLI utiltiy to install optimized react components in to React/Nextjs library",
  "type": "module",
  "bin": {
    "arkantos": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --clean",
    "dev": "tsdown src/index.ts --watch",
    "typecheck": "tsc --noEmit"
  },
  "tsdown": {
    "fixedExtension": false
  },
  "keywords": [
    "cli",
    "react",
    "nextjs",
    "components"
  ],
  "author": "Zaryab",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsdown": "^0.21.5",
    "typescript": "^6.0.2"
  }
}
