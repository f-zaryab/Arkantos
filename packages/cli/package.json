{
  "name": "arkantos",
  "version": "1.0.0",
  "description": "A CLI utiltiy to install optimized react components in to React/Nextjs library",
  "type": "module",
  "bin": {
    "arkantos": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --clean",
    "dev": "tsdown src/index.ts --watch",
    "typecheck": "tsc --noEmit"
  },
  "tsdown": {
    "fixedExtension": false
  },
  "keywords": [
    "cli",
    "react",
    "nextjs",
    "components"
  ],
  "author": "Zaryab",
  "license": "ISC",
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.5.2",
    "tsdown": "^0.21.5",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "fs-extra": "^11.3.4",
    "kleur": "^4.1.5",
    "ora": "^9.3.0",
    "zod": "^4.3.6"
  }
}
